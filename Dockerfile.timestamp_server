# Build:  docker build -f Dockerfile.timestamp_server -t timestamp_server .
# Run:    docker run -p 5555:5555 timestamp_server

# Build stage
FROM rust:1.86-slim AS builder

WORKDIR /app

COPY . .

RUN cargo build --release -p timestamp_server

# Runtime stage
FROM debian:bookworm-slim

COPY --from=builder /app/target/release/timestamp_server /usr/local/bin/timestamp_server

# EXPOSE 5555

CMD ["timestamp_server"]